# ========== LLM 配置 ==========

# LLM 提供商选择
# 可选值: claude, openai, qwen, deepseek, generic
LLM_PROVIDER=claude

# API 密钥（根据不同提供商设置）
LLM_API_KEY=your-api-key-here

# 模型名称（可选，留空使用默认模型）
# Claude: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# OpenAI: gpt-4, gpt-3.5-turbo
# Qwen: qwen-turbo, qwen-plus, qwen-max
# DeepSeek: deepseek-chat, deepseek-coder
LLM_MODEL=

# Base URL（仅用于 generic 提供商）
LLM_BASE_URL=

# 温度参数（0-1，越高越随机）
LLM_TEMPERATURE=0.7

# 最大 token 数
LLM_MAX_TOKENS=2000

# ========== 示例配置 ==========

# 使用 Claude
# LLM_PROVIDER=claude
# LLM_API_KEY=sk-ant-xxx
# LLM_MODEL=claude-3-5-sonnet-20241022

# 使用 OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4

# 使用通义千问
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-xxx
# LLM_MODEL=qwen-turbo

# 使用 DeepSeek
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# 使用自定义 OpenAI 兼容 API
# LLM_PROVIDER=generic
# LLM_API_KEY=xxx
# LLM_MODEL=model-name
# LLM_BASE_URL=https://your-api-endpoint.com/v1

# ========== 其他配置 ==========

# API Base URL
VITE_API_URL=http://localhost:8000
